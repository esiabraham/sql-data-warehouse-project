

/*
=============================================================
Creating Database and Schemas
=============================================================
This script creates a new database named 'DataWarehouse'. If the database already 
exists, it will be dropped and recreated from scratch. It also creates three schemas 
within the database: 'bronze', 'silver', and 'gold'.
	
PRECAUTION:
    Running this script will permanently delete the existing 'DataWarehouse' database 
    and all its data. This action cannot be undone. Make sure you have a backup 
    before proceeding.
*/


USE master;
GO

-- Drop and recreate the 'DataWarehouse' database
IF EXISTS (SELECT 1 FROM sys.databases WHERE name = 'DataWarehouse')
BEGIN
    ALTER DATABASE DataWarehouse SET SINGLE_USER WITH ROLLBACK IMMEDIATE;
    DROP DATABASE DataWarehouse;
END;
GO

-- Create the 'DataWarehouse' database
CREATE DATABASE DataWarehouse;
GO

USE DataWarehouse;
GO

-- Create Schemas
CREATE SCHEMA bronze;
GO

CREATE SCHEMA silver;
GO

CREATE SCHEMA gold;
GO
